# DB_PORT=1433
# DB_NAME=InhControlPredios
# DB_USER=sa
# DB_PASSWORD=Inh_Dev_123!
# DB_ENCRYPT=true
# DB_TRUST_CERT=true

# SQL Server remoto (producción / SSMS)
