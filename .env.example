# Frontend
# false = guarda en el navegador (localStorage / IndexedDB)
# true  = usa la API y SQL Server
VITE_USE_API=false
VITE_API_URL=

# Backend (cuando VITE_USE_API=true)
PORT=3001
JWT_SECRET=cambiar-este-secreto-en-produccion
CORS_ORIGIN=http://localhost:5173,https://chessman234.github.io

# --- Pruebas locales con Docker ---
# 1. Copy-Item .env.local.example .env.local
# 2. npm run db:up
# 3. npm run db:setup
# 4. npm run dev:api   (terminal 1)
# 5. npm run dev        (terminal 2)

# SQL Server local (Docker)
