# Copie este archivo como .env.local para pruebas con Docker + API local
# PowerShell: Copy-Item .env.local.example .env.local

# Frontend — conectar a la API local
VITE_USE_API=true
VITE_API_URL=http://localhost:3001

# Backend
PORT=3001
JWT_SECRET=inh-dev-local-secret
